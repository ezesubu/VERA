# VERA Environment Configuration
# Rename this file from .env.example to .env so VERA reads it.

# ---------------------------------------------------------
# 1. CHOOSE YOUR BRAIN (LLM_PROVIDER)
# Valid options: GEMINI, OPENAI, ANTHROPIC
# ---------------------------------------------------------
VERA_LLM_PROVIDER=OPENAI

# ---------------------------------------------------------
    # 2. CONFIGURE YOUR PAID KEYS (You only need the one for the provider you choose)
# ---------------------------------------------------------

# If you use OPENAI (ChatGPT-4o) - Recommended for maximum intelligence without strict limits
OPENAI_API_KEY="sk-your-openai-api-key-here"

# If you use ANTHROPIC (Claude 3.5 Sonnet)
ANTHROPIC_API_KEY="sk-ant-your-claude-api-key-here"

# If you use GEMINI (the one that ran out of credit)
GEMINI_API_KEY="your-gemini-api-key-here"
